# Dependencies
node_modules/
.venv/
__pycache__/
*.pyc
.pytest_cache/

# Builds
dist/
build/
.vite/

# Local config
.env
.env.*
!.env.example

# Secrets / credentials (defense in depth)
*.pem
*.key
!*.example.key
secrets.*
!secrets.*.example

# Firmware secrets (Wi-Fi creds, PC IP) - never commit
firmware/**/secrets.h
!firmware/**/secrets.h.example

# Backup / mirror clones of git history - never commit or push
*.git/
*-backup-*/
*.bak

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local generated output
assets/
