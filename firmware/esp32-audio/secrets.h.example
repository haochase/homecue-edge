// HomeCue Edge - firmware secrets TEMPLATE
// ----------------------------------------------------------------------------
// Copy this file to "secrets.h" (same folder) and fill in your values.
// secrets.h is gitignored and MUST NOT be committed. Do not put real Wi-Fi
// passwords or any API keys in source control.
//
//   PowerShell:  Copy-Item secrets.h.example secrets.h
//
// Button-route MVP: only WiFi + PC gateway are required. No ESP-SR models or
// vendor library paths. Flash with partition "16M Flash (3MB APP/9.9MB FATFS)".
//
#pragma once

// --- Wi-Fi (2.4 GHz; the ESP32-S3 does not join 5 GHz-only networks) --------
#define WIFI_SSID      "your-2.4ghz-ssid"
#define WIFI_PASSWORD  "your-wifi-password"

// --- PC FastAPI gateway on the same LAN --------------------------------------
// PC_HOST is your PC's LAN IPv4 address (run `ipconfig` -> IPv4 Address).
// Example ipconfig line:
//   无线局域网适配器 WLAN:
//      IPv4 地址 . . . . . . . . . . . . : 192.168.1.100
// Start the gateway bound to all interfaces so the board can reach it:
//   cd homecue-edge\apps\api
//   .\.venv\Scripts\python -m uvicorn app.main:app --host 0.0.0.0 --port 8723
// and allow inbound TCP 8723 through Windows Defender Firewall.
#define PC_HOST  "192.168.1.100"
#define PC_PORT  "8723"
